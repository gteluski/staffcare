# ============================================================================
# .env.example — Self-managed Supabase cutover template
# ============================================================================
# This file documents EVERY environment variable the project consumes.
# At cutover, copy to `.env` (Vite frontend) and configure Supabase Edge
# Function secrets via dashboard or `supabase secrets set ...`.
#
# DO NOT commit real values. All values below are PLACEHOLDERS.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. SUPABASE — frontend (Vite, public)
# ----------------------------------------------------------------------------
# Consumed by: src/integrations/supabase/client.ts, src/lib/chat-stream.ts
# Format: project ref is the subdomain piece of the project URL.
VITE_SUPABASE_PROJECT_ID="<NEW_PROJECT_REF>"
VITE_SUPABASE_URL="https://<NEW_PROJECT_REF>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<NEW_ANON_PUBLIC_KEY>"

# ----------------------------------------------------------------------------
# 2. STRIPE — frontend (Vite, public)
# ----------------------------------------------------------------------------
# Consumed by: src/lib/stripe.ts, src/components/PaymentTestModeBanner.tsx
# Use pk_test_... in development, pk_live_... in production.
# The frontend infers sandbox/live mode from the prefix automatically.
VITE_PAYMENTS_CLIENT_TOKEN="pk_test_<your_publishable_key>"

# ============================================================================
# 3. SUPABASE EDGE FUNCTION SECRETS (server-side only — NOT in this file)
# ============================================================================
# The variables below are consumed by edge functions and MUST be configured
# in the Supabase dashboard (Project Settings → Edge Functions → Secrets) or
# via CLI (`supabase secrets set KEY=value`). They are listed here for
# documentation only — they are NOT loaded from `.env` at runtime.
# ----------------------------------------------------------------------------

# --- 3a. Auto-injected by Supabase (DO NOT set manually) ---
# SUPABASE_URL              — auto
# SUPABASE_ANON_KEY         — auto
# SUPABASE_SERVICE_ROLE_KEY — auto
# SUPABASE_DB_URL           — auto

# --- 3b. Stripe (required for payments) ---
# Sandbox/test:
#   STRIPE_SANDBOX_API_KEY=sk_test_<your_real_stripe_secret>
#   PAYMENTS_SANDBOX_WEBHOOK_SECRET=whsec_<from_stripe_webhook_endpoint>
# Live (only when going to production):
#   STRIPE_LIVE_API_KEY=sk_live_<your_real_stripe_secret>
#   PAYMENTS_LIVE_WEBHOOK_SECRET=whsec_<from_stripe_webhook_endpoint>

# --- 3c. Chat AI provider (required) ---
# Pick ONE provider:
#   CHAT_PROVIDER=openai
#   OPENAI_API_KEY=sk-<your_openai_key>
# OR:
#   CHAT_PROVIDER=gemini
#   GEMINI_API_KEY=<your_google_ai_key>
# Optional model override (defaults: openai=gpt-5-mini, gemini=gemini-2.5-flash):
#   CHAT_MODEL=<explicit_model_name>

# --- 3d. Lovable Cloud only — DO NOT set in self-managed Supabase ---
# LOVABLE_API_KEY — only present in Lovable Cloud. Its absence is the
#   signal that switches `_shared/stripe.ts` to direct Stripe API mode.

# ============================================================================
# 4. OAUTH PROVIDERS (Supabase dashboard, not env)
# ============================================================================
# Configured manually in Supabase dashboard → Authentication → Providers:
#   - Google OAuth: Client ID + Client Secret from Google Cloud Console.
#     Authorized redirect URI: https://<NEW_PROJECT_REF>.supabase.co/auth/v1/callback
#   - Site URL + Redirect URLs: include all production and preview origins.

# ============================================================================
# 5. STRIPE WEBHOOK ENDPOINTS (Stripe dashboard, not env)
# ============================================================================
# Configured manually in Stripe dashboard → Developers → Webhooks:
#   Sandbox: https://<NEW_PROJECT_REF>.supabase.co/functions/v1/payments-webhook?env=sandbox
#   Live:    https://<NEW_PROJECT_REF>.supabase.co/functions/v1/payments-webhook?env=live
# Events: checkout.session.completed, customer.subscription.created,
#         customer.subscription.updated, customer.subscription.deleted,
#         invoice.paid, invoice.payment_failed